{
  "name": "codetrail-c-evidence-paths",
  "displayName": "CodeTrail: C Evidence Paths",
  "description": "Search unfamiliar C code as evidence-backed file and symbol paths.",
  "version": "0.1.2",
  "publisher": "crankysmh47",
  "author": {
    "name": "CodeTrail contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crankysmh47/CodeTrail.git"
  },
  "homepage": "https://github.com/crankysmh47/CodeTrail#readme",
  "bugs": {
    "url": "https://github.com/crankysmh47/CodeTrail/issues"
  },
  "icon": "media/icon.png",
  "keywords": [
    "C",
    "Linux kernel",
    "code navigation",
    "call graph",
    "static analysis",
    "MCP"
  ],
  "galleryBanner": {
    "color": "#101418",
    "theme": "dark"
  },
  "pricing": "Free",
  "preview": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "bin": {
    "codetrail-mcp": "./dist/mcp-server.cjs"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "CodeTrail reads workspace source files and starts a local analysis worker only after the folder is trusted."
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "activationEvents": [
    "onCommand:codetrail.indexWorkspace",
    "onCommand:codetrail.askQuestion",
    "onCommand:codetrail.explainSymbol",
    "onCommand:codetrail.discoverSymbolLinks",
    "onCommand:codetrail.discoverNode",
    "onCommand:codetrail.openSource"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codetrail.indexWorkspace",
        "title": "CodeTrail: Index Workspace"
      },
      {
        "command": "codetrail.askQuestion",
        "title": "CodeTrail: Search Code"
      },
      {
        "command": "codetrail.explainSymbol",
        "title": "CodeTrail: Explain Symbol"
      },
      {
        "command": "codetrail.discoverSymbolLinks",
        "title": "CodeTrail: Discover Symbol Links"
      },
      {
        "command": "codetrail.discoverNode",
        "title": "CodeTrail: Discover Indexed Function"
      },
      {
        "command": "codetrail.openSource",
        "title": "CodeTrail: Open Evidence Source"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codetrail.discoverSymbolLinks",
          "when": "editorLangId == c",
          "group": "navigation@20"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codetrail.discoverSymbolLinks",
        "key": "alt+shift+t",
        "mac": "alt+shift+t",
        "when": "editorTextFocus && editorLangId == c"
      }
    ],
    "configuration": {
      "title": "CodeTrail",
      "properties": {
        "codetrail.filesMax": {
          "type": "number",
          "default": 2000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of C source and header files indexed per workspace."
        },
        "codetrail.kernelEnrichment": {
          "type": "boolean",
          "default": false,
          "description": "Enable domain-specific enrichment for the Linux kernel scheduler."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "check": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "package": "npm run build && vsce package --out codetrail.vsix --no-dependencies --baseContentUrl https://github.com/crankysmh47/CodeTrail/blob/main --baseImagesUrl https://raw.githubusercontent.com/crankysmh47/CodeTrail/main",
    "mcp": "node dist/mcp-server.cjs",
    "evaluate:mcp": "npm run build && node scripts/run-mcp-evaluation.mjs",
    "evaluate:linux": "npm run build && node scripts/run-linux-evaluation.mjs",
    "test:mcp:e2e": "npm run build && vitest run src/mcp/stdio.e2e.test.ts",
    "verify:package": "node scripts/verify-package.mjs codetrail.vsix",
    "verify:release": "npm run check && npm test && npm run test:coverage && npm audit --omit=dev --audit-level=high && npm run package && npm run verify:package && npm run test:mcp:e2e"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "web-tree-sitter": "^0.20.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/vscode": "1.107.0",
    "@types/yauzl": "3.4.0",
    "@types/yazl": "3.3.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "jsdom": "^27.2.0",
    "tree-sitter-wasms": "0.1.13",
    "typescript": "7.0.2",
    "vitest": "4.1.0",
    "yauzl": "3.4.0",
    "yazl": "3.3.1"
  }
}
