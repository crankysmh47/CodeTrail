{
  "name": "codetrail",
  "displayName": "CodeTrail",
  "description": "Search unfamiliar C code as evidence-backed file and symbol paths.",
  "version": "0.1.0",
  "publisher": "codetrail-build-week",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "bin": {
    "codetrail-mcp": "./dist/mcp-server.cjs"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:codetrail.indexWorkspace",
    "onCommand:codetrail.askQuestion",
    "onCommand:codetrail.explainSymbol",
    "onCommand:codetrail.discoverSymbolLinks",
    "onCommand:codetrail.discoverNode",
    "onCommand:codetrail.openSource"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codetrail.indexWorkspace",
        "title": "CodeTrail: Index Workspace"
      },
      {
        "command": "codetrail.askQuestion",
        "title": "CodeTrail: Search Code"
      },
      {
        "command": "codetrail.explainSymbol",
        "title": "CodeTrail: Explain Symbol"
      },
      {
        "command": "codetrail.discoverSymbolLinks",
        "title": "CodeTrail: Discover Symbol Links"
      },
      {
        "command": "codetrail.discoverNode",
        "title": "CodeTrail: Discover Indexed Function"
      },
      {
        "command": "codetrail.openSource",
        "title": "CodeTrail: Open Evidence Source"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codetrail.discoverSymbolLinks",
          "when": "editorLangId == c",
          "group": "navigation@20"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codetrail.discoverSymbolLinks",
        "key": "alt+shift+t",
        "mac": "alt+shift+t",
        "when": "editorTextFocus && editorLangId == c"
      }
    ],
    "configuration": {
      "title": "CodeTrail",
      "properties": {
        "codetrail.filesMax": {
          "type": "number",
          "default": 2000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of C source and header files indexed per workspace."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "check": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "package": "npm run build && vsce package --out codetrail.vsix --no-dependencies --allow-missing-repository",
    "mcp": "node dist/mcp-server.cjs",
    "test:mcp:e2e": "npm run build && vitest run src/mcp/stdio.e2e.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "web-tree-sitter": "^0.20.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/vscode": "1.125.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "jsdom": "^27.2.0",
    "tree-sitter-wasms": "0.1.13",
    "typescript": "7.0.2",
    "vitest": "4.1.0"
  }
}
